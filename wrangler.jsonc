{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "carerforge-frontend",
  "main": "worker.js",
  "compatibility_date": "2026-07-09",

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}